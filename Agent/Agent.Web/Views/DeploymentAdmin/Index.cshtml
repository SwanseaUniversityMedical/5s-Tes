@using FiveSafesTes.Core.Models.ViewModels
@model JsonConfigUploadResponse
@{
    ViewData["Title"] = "Deployment Admin";
}


<div class="container-lg p-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <h1 class="fw-bold mb-1">Deployment Admin</h1>
            <p class="text-secondary mb-0">Manage submission configuration and monitor platform health.</p>
        </div>
        @if (Model != null && !Model.SyncJobExists)
        {
            <div class="d-flex align-items-center gap-3 rounded-3 px-3 py-2">
                <button id="hangfireRevivalBtn" class="btn btn-primary btn-sm d-flex align-items-center">
                    <span>Enable Sync</span>
                </button>
            </div>
        }
        else
        {
            <div class="d-flex align-items-center gap-3 rounded-3 px-3 py-2">
                <button disabled class="btn btn-primary btn-sm d-flex align-items-center">
                    <span>Sync Active</span>
                </button>
            </div>
        }
    </div>
    <h3>Upload Submission Configuration File</h3>
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> 
        <b>How to download the JSON configuration for your TRE.</b>
        <br/>
        <ul>
            <li>A submission admin will create a TRE and an account to manage it.</li>
            <li>These credentials will be shared with you. Use them to log into the submission layer.</li>
            <li>Navigate to the TREs tab. This TRE should be listed alongside a button that allows you to download its JSON configuration file.</li>
            <li>Please download this file and upload it below.</li>
        </ul>
    </div>
    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model.IsSynced && Model.IsUploaded)
            {
                <span class="badge  px-2 badge-sm bg-success text-light rounded-pill m-0 ms-3">
                    <i class="fa-solid fa-check-circle me-1"></i> Configuration uploaded and synced
                </span>
            }
            else if (Model.IsUploaded)
            {
                <span class="badge  px-2 badge-sm bg-grey text-dark rounded-pill m-0 ms-3">
                    <i class="fa-solid fa-ban me-1"></i> Configuration uploaded but not yet synced
                </span>
            }
            else
            {
                <span class="badge  px-2 badge-sm bg-grey text-dark rounded-pill m-0 ms-3">
                    <i class="fa-solid fa-ban me-1"></i> No configuration has been uploaded
                </span>
            }
        </div>
    </div>
    <div class="card shadow-sm">
        <div class="card-body">

            @{
                if (Model != null && !string.IsNullOrEmpty(Model.Message))
                {
                    if (Model.Success)
                    {
                        <div class="alert alert-info">
                            @Model.Message
                        </div>
                    }
                    else
                    {
                        <div class="modal-header bg-danger text-white">
                            @Model.Message
                        </div>
                        <br/>
                    }
                }
            }

            <form asp-controller="DeploymentAdmin" asp-action="UploadJsonConfig" method="post" enctype="multipart/form-data">
                <input type="file" name="file" />
                <button type="submit">Upload</button>
            </form>
        </div>
    </div>
</div>
<div class="container-lg px-4">
    <div class="row">
        <div class="col-sm-12 col-md-6">
            <h3>Health Check Status</h3>
        </div>
        
    </div>
    <div>
        <div class="tab-pane" id="" role="tabpanel" aria-labelledby="statuses">
            @await Html.PartialAsync("_StatusTable", Model.HealthCheckStatus)
        </div>
    </div>
</div>


<script>
    document.getElementById("hangfireRevivalBtn").addEventListener("click", async function () {
        const response = await fetch('/DeploymentAdmin/ReviveHangfireJobs', { method: 'POST' });
         location.reload();
    });
</script>
