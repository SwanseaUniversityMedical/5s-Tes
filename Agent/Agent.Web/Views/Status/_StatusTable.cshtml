<div class="container-lg mt-4 p-4 bg-white border-1 shadow-sm">
    <div>
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <table id="statusTable" class="rounded-lg">
                    <thead>
                        <tr>
                            <th class="text-nowrap" style="width: 20%;">ID</th>
                            <th class="text-nowrap" style="width: 20%;">Product</th>
                            <th class="text-nowrap" style="width: 20%;">Health Status</th>
                            <th class="text-nowrap" style="width: 20%;">Reason</th>
                            <th class="text-nowrap" style="width: 20%;">Datetime</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var status in ViewBag.Statuses)
                        {
                            <tr>
                                <td>@status.Id</td>
                                <td>@status.Product</td>
                                <td>@status.HealthStatus</td>
                                <td>@status.Reason</td>
                                <td>@status.Datetime?.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/DataTables/datatables.min.js"></script>
    <link rel="stylesheet" href="~/lib/DataTables/datatables.min.css" />

    <script>

        new DataTable('#statusTable');

    </script>
}
